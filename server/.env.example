# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/f1
DB_USER=postgres
DB_HOST=localhost
DB_NAME=f1
DB_PASSWORD=password
DB_PORT=5432
PG_POOL_MAX=5

# ── Auth ──────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=tu_password_admin
JWT_SECRET=tu_jwt_secret_aqui

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
# 1. En dash.cloudflare.com → R2 → Crear bucket (ej: f1-grand-prix-hub)
# 2. R2 → Manage R2 API Tokens → Create API Token (permisos: Object Read & Write)
# 3. Habilitar acceso público en el bucket → copiar la URL r2.dev o tu custom domain

CLOUDFLARE_ACCOUNT_ID=tu_account_id_aqui
CLOUDFLARE_R2_ACCESS_KEY=tu_access_key_aqui
CLOUDFLARE_R2_SECRET_KEY=tu_secret_key_aqui
CLOUDFLARE_R2_BUCKET=f1-grand-prix-hub
CLOUDFLARE_R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXX.r2.dev
# Si tenés custom domain: CLOUDFLARE_R2_PUBLIC_URL=https://images.tudominio.com
